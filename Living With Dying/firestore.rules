rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Rule: Deny all (Secure by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // Custom functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isSuperAdmin() {
      return isAuthenticated() && getUserData().role == 'superadmin';
    }

    function isAdmin() {
      let role = getUserData().role;
      return isAuthenticated() && (role == 'superadmin' || role == 'masteradmin' || role == 'admin' || role == 'manager');
    }

    // 1. Users Collection
    match /users/{userId} {
      // Anyone can read if they are logged in (to see opponents/leaderboards)
      allow read: if isAuthenticated();
      // Users can only create their own document when they sign up
      allow create: if request.auth.uid == userId;
      // Users can update their own document, admins can update any user document
      allow update: if request.auth.uid == userId || isAdmin();
      // Only SuperAdmin can delete users
      allow delete: if isSuperAdmin();
    }

    // 2. Tournaments Collection (AnimeContent refactored to Tournaments)
    match /content/{contentId} {
      // Anyone can read published tournaments
      allow read: if true;
      // Only Admins can create or update or delete
      allow write: if isAdmin();
    }

    // 3. User Requests (e.g., support requests)
    match /requests/{requestId} {
      // Users can create a request, Admins can read/update all
      // Users can also read and delete their own requests
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow update, delete: if isAdmin() || request.auth.uid == resource.data.userId;
    }

    // 4. Advertisements / Campaigns
    match /ads/{adId} {
      // Anyone can read active ads
      allow read: if true;
      allow write: if isAdmin();
    }

    // 5. System Settings
    match /settings/{settingId} {
      // Anyone can read settings (e.g. isLocked, broadcast message)
      allow read: if true;
      allow write: if isAdmin();
    }

    // 6. Bug Reports
    match /bugReports/{bugId} {
      allow create: if true; // Even unauthenticated users might report bugs during sign-in
      allow read, update, delete: if isAdmin();
    }

    // 7. Live Support Chats
    match /support_chats/{userId} {
      // Users can read/write their own chat document. Admins/Managers can read/write all.
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || getUserData().role == 'manager');
      
      // Messages subcollection
      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && (request.auth.uid == userId || isAdmin() || getUserData().role == 'manager');
      }
    }

    // 8. Aiko AI History
    match /aiko_chats/{userId} {
      // Only the specific user can read/write their own AI history
      allow read, write: if isAuthenticated() && request.auth.uid == userId;

      match /messages/{messageId} {
        allow read, write: if isAuthenticated() && request.auth.uid == userId;
      }
    }

    // 9. News Section
    match /news/{newsId} {
      // Anyone can read the news (including guests)
      allow read: if true;
      // Only Super Admins / Master Admins can create/edit/delete news
      allow write: if isSuperAdmin();
    }

    // 10. Admin Activity (User uploads/engagement tracking)
    match /admin_activity/{activityId} {
      // Anyone can read (for leaderboards/stats)
      allow read: if true;
      // Only admins can write to their own activity records
      allow write: if isAdmin();
    }

    // 11. Tournament Registrations ← NEW
    match /registrations/{registrationId} {
      // Any logged-in user can register (create) for a tournament
      allow create: if isAuthenticated();
      // Users can read and delete their own registration (for unregistering/refunds)
      allow read, delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      // Only admins can update registration status (e.g. mark as verified)
      allow update: if isAdmin();
    }

    // 12. User Reports (in-game, abuse, etc.) ← NEW
    match /reports/{reportId} {
      // Any logged-in user can submit a report
      allow create: if isAuthenticated();
      // Users can read their own reports; Admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.reportedBy || isAdmin());
      // Only admins can update or delete reports (e.g. mark as resolved)
      allow update, delete: if isAdmin();
    }

    // 13. Comments on Tournaments ← NEW
    match /comments/{commentId} {
      // Anyone logged in can read comments
      allow read: if isAuthenticated();
      // Any logged-in user can post a comment
      allow create: if isAuthenticated();
      // Users can delete their own comments; admins can delete any
      allow delete: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      // Only admins can update (moderate) comments
      allow update: if isAdmin();
    }

    // 14. Financials (Transactions & Wallet Credits)
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /credit_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin();
    }

    match /deposit_requests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    match /withdrawal_requests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // 15. Team Requests ← NEW
    match /team_requests/{requestId} {
      // Any logged in user can send a request
      allow create: if isAuthenticated();
      // Users can only read/update/delete requests they are involved in
      allow read, update, delete: if isAuthenticated() && (request.auth.uid == resource.data.senderId || request.auth.uid == resource.data.receiverId || isAdmin());
    }

  }
}